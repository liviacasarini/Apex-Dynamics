{
  "name": "race-telemetry-analyzer",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-key": "node scripts/generate-license.js",
    "electron:dev": "set NODE_ENV=development && electron electron/main.cjs",
    "build:vite": "cross-env NODE_ENV=production vite build",
    "deploy": "node scripts/deploy.cjs",
    "build:dir": "npm run build:vite && electron-builder --win --dir && start release\\win-unpacked\\ApexDynamics.exe",
    "build:win": "npm run build:vite && electron-builder --win",
    "build:mac": "npm run build:vite && electron-builder --mac"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "gopro-telemetry": "^1.2.11",
    "gpmf-extract": "^0.3.2",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "terser": "^5.31.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.apexdynamics.racing",
    "productName": "ApexDynamics",
    "copyright": "Copyright © 2025-2026 ApexDynamics",
    "afterPack": "./scripts/embed-icon.cjs",
    "asar": true,
    "asarUnpack": [],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/*.map",
      "!**/node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "${productName}.Setup.${version}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ApexDynamics",
      "deleteAppDataOnUninstall": false,
      "license": "public/license.rtf"
    },
    "publish": null
  }
}
